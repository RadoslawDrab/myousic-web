{
  "compilerOptions": {
    "types": [
      "vite/client",
      "unplugin-vue-router/client"
    ],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strictBindCallApply": true,
    "strict": false,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@public/*": ["./public/*"],
    }
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.vue",
    "./.config/*.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
